---
import { getCollection } from "astro:content";
import { findBusiness, getBusinessEntries, toDeliveryLinks } from "../data/business";
import Header from "../components/Header.svelte";
import Footer from "../components/Footer.svelte";
import "../assets/styles/global.css";

export interface Props {
  title?: string;
}

const { title = "Vons Coffee House" } = Astro.props;

const businessEntries = await getBusinessEntries();
const address = findBusiness(businessEntries, "Address");
const phone = findBusiness(businessEntries, "Phone");
const email = findBusiness(businessEntries, "Email");
const hours = findBusiness(businessEntries, "Hours");
const instagram = findBusiness(businessEntries, "Instagram");
const facebook = findBusiness(businessEntries, "Facebook");
const deliveryEntries = await getCollection("delivery");
const deliveryLinks = toDeliveryLinks(deliveryEntries);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="text-neutral-50">
    <Header currentPath={Astro.url.pathname} deliveryLinks={deliveryLinks} client:load />
    <slot />
    <Footer {address} {phone} {email} {hours} {instagram} {facebook} {deliveryLinks} />
  </body>
</html>
