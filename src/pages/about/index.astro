---
import { getCollection } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";

const entries = await getCollection("business");

function isUrl(value: string) {
  return value.startsWith("http://") || value.startsWith("https://");
}
---

<PageLayout>
  <main class="max-w-3xl mx-auto p-6">
    {entries.length > 0 ? (
      <>
        {entries
          .filter((e) => e.data.name === "About")
          .map((e) => (
            <p class="text-lg text-gray-600 mb-6">{e.data.value}</p>
          ))}

        <div class="space-y-3 mb-8">
          {entries
            .filter((e) => e.data.name !== "About")
            .map((e) => (
              <div>
                <span class="font-semibold">{e.data.name}:</span>{" "}
                {isUrl(e.data.value) ? (
                  <a
                    href={e.data.value}
                    class="text-blue-600 underline"
                    target="_blank"
                  >
                    {e.data.value}
                  </a>
                ) : (
                  <span>{e.data.value}</span>
                )}
              </div>
            ))}
        </div>
      </>
    ) : (
      <p class="text-gray-500">Business information coming soon.</p>
    )}
  </main>
</PageLayout>
