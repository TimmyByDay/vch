---
import { getCollection } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";

const specials = await getCollection("specials");
const rendered = await Promise.all(
  specials.map(async (entry) => {
    const { Content } = await entry.render();
    return { ...entry, Content };
  }),
);
---

<PageLayout title="Specials">
  <main class="max-w-3xl mx-auto p-6">
    <h1 class="text-3xl font-bold mb-8">Specials</h1>
    {rendered.length === 0 && <p class="text-neutral-200">No current specials.</p>}
    <div class="grid gap-6">
      {rendered.map((entry) => {
        const { title, description, startDate, endDate } = entry.data;
        return (
          <article class="border border-neutral-700 rounded-lg p-6">
            <h2 class="text-xl font-semibold mb-2">{title}</h2>
            <p class="text-sm text-neutral-200 mb-3">
              {new Date(startDate).toLocaleDateString()}
              {endDate && ` — ${new Date(endDate).toLocaleDateString()}`}
            </p>
            <p class="text-neutral-100 mb-3">{description}</p>
            <div class="prose prose-sm max-w-none prose-invert text-neutral-100">
              <entry.Content />
            </div>
          </article>
        );
      })}
    </div>
  </main>
</PageLayout>
