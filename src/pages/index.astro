---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout title="Home">
  <main class="max-w-3xl mx-auto p-6">
    <h1 class="text-3xl font-bold mb-2">Vons Coffee House</h1>
    <p class="text-neutral-200 mb-8">St Austell's quirky coffee house</p>

    <nav class="space-y-3">
      <a
        href="/menu"
        class="block text-neutral-50 underline text-lg"
      >
        Menu
      </a>
      <a
        href="/specials"
        class="block text-neutral-50 underline text-lg"
      >
        Specials
      </a>
      <a
        href="/about"
        class="block text-neutral-50 underline text-lg"
      >
        About
      </a>
    </nav>
  </main>
</PageLayout>
