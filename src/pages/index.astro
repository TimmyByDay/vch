---
import { getCollection } from "astro:content";
import PageLayout from "../layouts/PageLayout.astro";
import FloatingSlideshow from "../components/FloatingSlideshow.svelte";
import FeaturedCard from "../components/FeaturedCard.svelte";
import { deliveryIcons } from "../data/delivery";
import { toDeliveryLinks, findBusiness, getBusinessEntries } from "../data/business";

const deliveryEntries = await getCollection("delivery");
const deliveryLinks = toDeliveryLinks(deliveryEntries);

const drinkEntries = await getCollection("drinks");
const foodEntries = await getCollection("food");
const cakeEntries = await getCollection("cakes");
const drinkImages = [
  "/hero/drink/drink.png",
  "/hero/drink/drink2.png",
  "/hero/drink/drink3.png",
  "/hero/drink/drink4.png",
];

const foodImages = [
  "/hero/food/food1.png",
  "/hero/food/food2.png",
  "/hero/food/food3.png",
  "/hero/food/food4.png",
];

const brewingItems = drinkEntries.filter((e) => e.data.featured).map((e) => e.data).slice(0, 3);

const bakingItems = [
  ...foodEntries.filter((e) => e.data.featured).map((e) => e.data),
  ...cakeEntries.filter((e) => e.data.featured).map((e) => e.data),
].slice(0, 3);

const allSpecials = [
  ...drinkEntries.filter((e) => e.data.special).map((e) => ({ ...e.data })),
  ...foodEntries.filter((e) => e.data.special).map((e) => ({ ...e.data })),
  ...cakeEntries.filter((e) => e.data.special).map((e) => ({ ...e.data })),
];

const businessEntries = await getBusinessEntries();
const hours = findBusiness(businessEntries, "Hours");
const address = findBusiness(businessEntries, "Address");
const phone = findBusiness(businessEntries, "Phone");
const email = findBusiness(businessEntries, "Email");
const instagram = findBusiness(businessEntries, "Instagram");
const facebook = findBusiness(businessEntries, "Facebook");

const about = findBusiness(businessEntries, "About");
const testimonials = await getCollection("testimonials");

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CafeOrCoffeeShop",
  name: "Vons Coffee House",
  image: "https://vonscoffeehouse.com/hero3.jpg",
  url: "https://vonscoffeehouse.com",
  telephone: phone,
  email: email,
  description: about,
  address: {
    "@type": "PostalAddress",
    streetAddress: address,
    addressLocality: "St Austell",
    addressCountry: "GB",
  },
  openingHoursSpecification: [
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday","Tuesday","Wednesday","Thursday","Friday"], opens: "10:30", closes: "16:00" },
    { "@type": "OpeningHoursSpecification", dayOfWeek: "Saturday", opens: "10:30", closes: "15:00" },
  ],
  sameAs: [instagram, facebook].filter(Boolean),
};
---

<PageLayout title="Home">
  <section class="relative min-h-[65vh] md:min-h-[45vh] overflow-hidden -mt-16 pt-12 pb-16">
    <div class="absolute inset-0 z-0 text-accent/10 pointer-events-none" aria-hidden="true">
      <svg class="absolute top-0 left-0 -translate-x-1/3 -translate-y-1/3" width="600" height="600" viewBox="0 0 600 600" fill="none">
        <path d="M515.266 181.33C377.943 51.564 128.537 136.256 50.8123 293.565C-26.9127 450.874 125.728 600 125.728 600" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
      <svg class="absolute bottom-0 right-0 translate-x-1/4 translate-y-1/4" width="700" height="700" viewBox="0 0 700 700" fill="none">
        <path d="M26.8838 528.274C193.934 689.816 480.051 637.218 594.397 451.983C708.742 266.748 543.953 2.22235 543.953 2.22235" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </div>
    <div class="absolute inset-0 hero-bg-image" />
    <div class="absolute inset-0 bg-white/97" />
    <div class="absolute inset-0 z-[5] pointer-events-none overflow-hidden">
      <FloatingSlideshow
        client:load
        positionClass="left-1/2 -translate-x-43 md:-translate-x-72 top-[62%] md:top-[65%]"
        sizeClass="w-20 md:w-24"
        images={drinkImages}
        rotation={-15}
        rotationY={14}
        floatDelay="0ms"
      />
      <FloatingSlideshow
        client:load
        positionClass="left-1/2 translate-x-22 md:translate-x-48 top-[62%] md:top-[65%]"
        sizeClass="w-20 md:w-24"
        images={foodImages}
        rotation={15}
        rotationY={-10}
        floatDelay="150ms"
      />
    </div>
    <div class="relative z-10 text-center px-4 max-w-3xl mx-auto pt-24 md:pt-32">
      <span class="inline-block bg-accent/10 text-accent text-xs tracking-wider uppercase rounded-full px-4 py-1.5 mb-5">
        Vegan-friendly
      </span>
      <h1 class="text-3xl md:text-5xl text-neutral-900 mb-4">
        Freshly <span class="font-bold">Brewed</span>. Freshly <span class="font-bold">Baked</span>. Freshly <span class="font-bold">Served</span>.
      </h1>
      <p class="text-neutral-600 text-base md:text-lg">
        Artisan coffee and fresh bakes in St. Austell
      </p>
      <div class="mt-8 md:mt-10 flex flex-col md:flex-row items-center justify-center gap-4 md:gap-6">
        <span class="inline-block rounded-full shadow-button">
          <a
            href="/menu"
            class="block bg-secondary px-10 py-4 rounded-full text-white font-semibold transition-all hover:-translate-y-1"
          >
            View Menu
          </a>
        </span>
        <a
          href="/contact"
          class="inline-block border-2 border-secondary/60 px-8 py-3 rounded-full text-secondary font-semibold transition-all hover:border-secondary text-sm"
        >
          Find Us
        </a>
      </div>
      <div class="mt-12 flex items-center justify-center gap-x-6 md:gap-x-10 text-sm text-neutral-500">
        {deliveryLinks.map((link, i) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 font-semibold text-secondary hover:text-accent transition-colors"
          >
            <span class={`delivery-icon-${i} w-6 h-6 flex-shrink-0 flex items-center justify-center icon-svg`} set:html={deliveryIcons[link.name]} />
            {link.name}
          </a>
        ))}
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent" />
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

  {brewingItems.length > 0 && (
    <section class="py-16 px-4 max-w-6xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center text-neutral-900 mb-6 md:mb-10">
        What&apos;s Brewing
      </h2>
      <div class="flex flex-wrap justify-center gap-6">
        {brewingItems.map((item) => (
          <div class="w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]">
            <FeaturedCard
              client:load
              name={item.name}
              description={item.description}
              price={item.price}
              vegan={item.vegan}
              special={item.special}
              specialPrice={item.specialPrice}
              label={item.label}
            />
          </div>
        ))}
      </div>
    </section>
  )}

  {bakingItems.length > 0 && (
    <section class="pb-16 px-4 max-w-6xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center text-neutral-900 mb-6 md:mb-10">
        What&apos;s Baking
      </h2>
      <div class="flex flex-wrap justify-center gap-6">
        {bakingItems.map((item) => (
          <div class="w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)]">
            <FeaturedCard
              client:load
              name={item.name}
              description={item.description}
              price={item.price}
              vegan={item.vegan}
              special={item.special}
              specialPrice={item.specialPrice}
              label={item.label}
            />
          </div>
        ))}
      </div>
    </section>
  )}

  {allSpecials.length > 0 && (
    <section class="pb-16 px-4 max-w-3xl mx-auto">
      <div class="bg-accent/5 border border-accent/20 rounded-xl p-6 md:p-8 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-900 mb-2">
          This Week's Specials
        </h2>
        <p class="text-neutral-600 mb-6 text-sm">Limited-time deals you won't want to miss</p>
        <div class="flex flex-wrap justify-center gap-4">
          {allSpecials.map((item) => (
            <span class="inline-flex items-center gap-2 bg-white/80 rounded-full px-4 py-2 text-sm font-medium text-neutral-900">
              {item.name}
              <span class="text-accent font-semibold">{item.specialPrice}</span>
            </span>
          ))}
        </div>
        <div class="mt-6">
          <a href="/menu" class="text-sm font-semibold text-secondary hover:text-accent underline underline-offset-2">
            View full menu &rarr;
          </a>
        </div>
      </div>
    </section>
  )}

  {testimonials.length > 0 && (
    <section class="pb-16 px-4 max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center text-neutral-900 mb-6 md:mb-10">
        What People Say
      </h2>
      <div class="grid md:grid-cols-3 gap-4 md:gap-6">
        {testimonials.map((entry) => (
          <div class="bg-neutral-50/20 rounded-xl p-5 md:p-6 flex flex-col">
            <p class="text-neutral-600 text-sm leading-relaxed flex-1">&ldquo;{entry.data.quote}&rdquo;</p>
            <p class="text-neutral-900 font-semibold text-sm mt-3 md:mt-4">&mdash; {entry.data.author}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  {hours && (
    <section class="pb-16 px-4">
      <div class="max-w-sm mx-auto bg-neutral-50 rounded-xl p-5 md:p-6 text-center">
        <h2 class="text-lg font-semibold text-neutral-900 mb-2">Opening Hours</h2>
        <p class="text-neutral-600 text-sm whitespace-pre-line">{hours}</p>
      </div>
    </section>
  )}
</PageLayout>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
     50% { transform: translateY(-8px); }
  }
  :global(.animate-float) {
    animation: float 7s ease-in-out infinite;
  }
  .hero-bg-image {
    background-image: url('/hero3.jpg');
    background-size: cover;
    background-position: center;
  }
</style>

<style set:html={deliveryLinks.map((link, i) => `.delivery-icon-${i} { color: ${link.color}; }`).join('')} />
