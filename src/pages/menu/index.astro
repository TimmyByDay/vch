---
import { getCollection } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";

const drinks = await getCollection("drinks");
const food = await getCollection("food");
const cakes = await getCollection("cakes");

const drinkCategories = [...new Set(drinks.map((entry) => entry.data.category))];
const foodCategories = [...new Set(food.map((entry) => entry.data.category))];

function formatCategory(cat: string) {
  return cat
    .split("-")
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
}
---

<PageLayout title="Menu">
  <main class="max-w-3xl mx-auto p-6">
    <h1 class="text-3xl font-bold mb-8">Menu</h1>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold mb-4">Drinks</h2>
      {drinkCategories.map((cat) => {
        const items = drinks.filter((entry) => entry.data.category === cat);
        if (items.length === 0) return null;
        return (
          <div class="mb-6">
            <h3 class="text-lg font-medium text-neutral-100 mb-2">
              {formatCategory(cat)}
            </h3>
            <ul class="space-y-2">
              {items.map((entry) => (
                <li class="border-b border-neutral-800 pb-2 pt-1">
                  <div class="flex justify-between items-start">
                    <div class="flex-1 pr-4">
                      <div class="flex items-center gap-2 flex-wrap">
                        <span class="font-medium">{entry.data.name}</span>
                        {entry.data.vegan && (
                          <span class="text-xs bg-accent/20 text-accent rounded-full px-2 py-0.5 font-medium">Vegan</span>
                        )}
                      </div>
                      {entry.data.description && (
                        <p class="text-sm text-neutral-400 mt-0.5">{entry.data.description}</p>
                      )}
                    </div>
                    <span class="flex-shrink-0">
                      {entry.data.special && entry.data.specialPrice ? (
                        <>
                          <span class="line-through text-red-400/60">{entry.data.price}</span>
                          <span class="ml-2 font-semibold text-neutral-50">{entry.data.specialPrice}</span>
                        </>
                      ) : (
                        <span class="text-neutral-200">{entry.data.price}</span>
                      )}
                    </span>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold mb-4">Food</h2>
      {foodCategories.map((cat) => {
        const items = food.filter((entry) => entry.data.category === cat);
        if (items.length === 0) return null;
        return (
          <div class="mb-6">
            <h3 class="text-lg font-medium text-neutral-100 mb-2">
              {formatCategory(cat)}
            </h3>
            <ul class="space-y-2">
              {items.map((entry) => (
                <li class="border-b border-neutral-800 pb-2 pt-1">
                  <div class="flex justify-between items-start">
                    <div class="flex-1 pr-4">
                      <div class="flex items-center gap-2 flex-wrap">
                        <span class="font-medium">{entry.data.name}</span>
                        {entry.data.vegan && (
                          <span class="text-xs bg-accent/20 text-accent rounded-full px-2 py-0.5 font-medium">Vegan</span>
                        )}
                      </div>
                      {entry.data.description && (
                        <p class="text-sm text-neutral-400 mt-0.5">{entry.data.description}</p>
                      )}
                    </div>
                    <span class="flex-shrink-0">
                      {entry.data.special && entry.data.specialPrice ? (
                        <>
                          <span class="line-through text-red-400/60">{entry.data.price}</span>
                          <span class="ml-2 font-semibold text-neutral-50">{entry.data.specialPrice}</span>
                        </>
                      ) : (
                        <span class="text-neutral-200">{entry.data.price}</span>
                      )}
                    </span>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold mb-4">Cakes & Bakes</h2>
      <ul class="space-y-2">
        {cakes.map((entry) => (
          <li class="border-b border-neutral-800 pb-2 pt-1">
            <div class="flex justify-between items-start">
              <div class="flex-1 pr-4">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="font-medium">{entry.data.name}</span>
                  {entry.data.vegan && (
                    <span class="text-xs bg-accent/20 text-accent rounded-full px-2 py-0.5 font-medium">Vegan</span>
                  )}
                </div>
                {entry.data.description && (
                  <p class="text-sm text-neutral-400 mt-0.5">{entry.data.description}</p>
                )}
              </div>
              <span class="flex-shrink-0">
                {entry.data.special && entry.data.specialPrice ? (
                  <>
                    <span class="line-through text-red-400/60">{entry.data.price}</span>
                    <span class="ml-2 font-semibold text-neutral-50">{entry.data.specialPrice}</span>
                  </>
                ) : (
                  <span class="text-neutral-200">{entry.data.price}</span>
                )}
              </span>
            </div>
          </li>
        ))}
      </ul>
    </section>
  </main>
</PageLayout>
